---
import { getAllCases } from '@lib/cases';

const cases = await getAllCases();
const caseCount = cases.length;
const activeCases = cases.filter((c) => c.data.status === 'investigating').length;
---

<header class="sticky top-0 z-50 bg-manila-50/80 dark:bg-dark-bg/80 backdrop-blur-md border-b border-manila-300 dark:border-dark-border">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <!-- Logo / Brand -->
    <a
      href="/"
      class="flex items-center gap-3 group"
      transition:name="nav-logo"
    >
      <div class="w-8 h-8 bg-stamp-red rounded-sm flex items-center justify-center transform -rotate-3 group-hover:rotate-0 transition-transform">
        <span class="text-white font-mono font-bold text-sm">CF</span>
      </div>
      <div class="flex flex-col">
        <span class="font-serif font-bold text-lg text-ink dark:text-dark-text leading-tight">
          CaseFiles
        </span>
        <span class="font-mono text-[10px] text-ink-muted dark:text-dark-muted uppercase tracking-widest">
          Incident Postmortems
        </span>
      </div>
    </a>

    <!-- Right side controls -->
    <div class="flex items-center gap-4">
      <!-- Case counter badge -->
      <div class="hidden sm:flex items-center gap-2 font-mono text-xs text-ink-muted dark:text-dark-muted">
        <span class="bg-manila-200 dark:bg-dark-card px-2 py-1 rounded-sm border border-manila-300 dark:border-dark-border">
          {caseCount} cases
        </span>
        {activeCases > 0 && (
          <span class="bg-stamp-red/10 text-stamp-red px-2 py-1 rounded-sm border border-stamp-red/30 animate-pulse">
            {activeCases} active
          </span>
        )}
      </div>

      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        class="w-9 h-9 flex items-center justify-center rounded-sm bg-manila-200 dark:bg-dark-card border border-manila-300 dark:border-dark-border hover:bg-manila-300 dark:hover:bg-dark-border transition-colors cursor-pointer"
        aria-label="Toggle dark mode"
      >
        <svg id="sun-icon" class="w-4 h-4 hidden dark:block text-dark-text" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5" />
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
        <svg id="moon-icon" class="w-4 h-4 block dark:hidden text-ink" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="sm:hidden w-9 h-9 flex items-center justify-center rounded-sm bg-manila-200 dark:bg-dark-card border border-manila-300 dark:border-dark-border cursor-pointer"
        aria-label="Open menu"
      >
        <svg class="w-4 h-4 text-ink dark:text-dark-text" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile drawer -->
  <div
    id="mobile-drawer"
    class="hidden sm:hidden fixed inset-0 z-50 bg-ink/50 dark:bg-black/50"
  >
    <div class="absolute right-0 top-0 h-full w-64 bg-manila-50 dark:bg-dark-bg border-l border-manila-300 dark:border-dark-border p-6 transform transition-transform">
      <button id="close-drawer" class="absolute top-4 right-4 text-ink dark:text-dark-text cursor-pointer">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <nav class="mt-10 space-y-4">
        <a href="/" class="block font-mono text-sm text-ink dark:text-dark-text hover:text-stamp-red transition-colors">
          All Cases
        </a>
        <div class="font-mono text-xs text-ink-muted dark:text-dark-muted mt-4">
          {caseCount} cases filed
        </div>
        {activeCases > 0 && (
          <div class="font-mono text-xs text-stamp-red">
            {activeCases} active investigation{activeCases > 1 ? 's' : ''}
          </div>
        )}
      </nav>
    </div>
  </div>
</header>

<script is:inline>
  // Re-run on every page load (including View Transitions)
  document.addEventListener('astro:page-load', () => {
    // ─── Dark mode toggle ──────────────────────────
    const toggle = document.getElementById('theme-toggle');
    if (toggle) {
      // Remove any previous listeners by cloning
      const freshToggle = toggle.cloneNode(true);
      toggle.parentNode?.replaceChild(freshToggle, toggle);

      freshToggle.addEventListener('click', () => {
        const html = document.documentElement;
        const isDark = html.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    }

    // ─── Mobile drawer ────────────────────────────
    const menuBtn = document.getElementById('mobile-menu-btn');
    const drawer = document.getElementById('mobile-drawer');
    const closeBtn = document.getElementById('close-drawer');

    menuBtn?.addEventListener('click', () => {
      drawer?.classList.remove('hidden');
    });
    closeBtn?.addEventListener('click', () => {
      drawer?.classList.add('hidden');
    });
    drawer?.addEventListener('click', (e) => {
      if (e.target === drawer) drawer.classList.add('hidden');
    });
  });
</script>
