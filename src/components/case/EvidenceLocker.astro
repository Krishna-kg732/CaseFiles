---
import type { EvidenceItem } from '@types/case';

interface Props {
  evidence: EvidenceItem[];
}

const { evidence } = Astro.props;

// Compute rotation for each polaroid
const rotations = evidence.map((_, i) => {
  const rotations = [-3, 2, -1, 3, -2, 1];
  return rotations[i % rotations.length];
});
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
  {evidence.map((item, index) => (
    <div
      class="polaroid cursor-pointer"
      style={`--rotate: ${rotations[index]}deg`}
      data-lightbox-trigger={index}
    >
      <div class="relative aspect-video bg-manila-200 dark:bg-dark-border overflow-hidden rounded-sm">
        <img
          src={item.file}
          alt={item.label}
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
          loading="lazy"
        />
      </div>
      <div class="mt-3 text-center">
        <span class="font-mono text-xs text-ink-muted dark:text-dark-muted uppercase tracking-wider">
          {item.label}
        </span>
      </div>
    </div>
  ))}
</div>

<!-- Simple lightbox overlay -->
<div
  id="lightbox-overlay"
  class="fixed inset-0 z-50 hidden bg-ink/90 dark:bg-black/90 flex items-center justify-center cursor-zoom-out"
>
  <button
    id="lightbox-close"
    class="absolute top-4 right-4 text-white text-2xl font-bold hover:opacity-70 transition-opacity cursor-pointer"
    aria-label="Close lightbox"
  >
    ✕
  </button>
  <img id="lightbox-img" class="max-w-[90vw] max-h-[85vh] object-contain" src="" alt="" />
  <div id="lightbox-label" class="absolute bottom-6 left-1/2 -translate-x-1/2 font-mono text-xs text-white/80 uppercase tracking-wider"></div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const overlay = document.getElementById('lightbox-overlay');
    const img = document.getElementById('lightbox-img') as HTMLImageElement;
    const label = document.getElementById('lightbox-label');
    const closeBtn = document.getElementById('lightbox-close');

    if (!overlay || !img || !label) return;

    // Open lightbox
    for (const trigger of document.querySelectorAll<HTMLElement>('[data-lightbox-trigger]')) {
      trigger.addEventListener('click', () => {
        const triggerImg = trigger.querySelector('img');
        const triggerLabel = trigger.querySelector('span');
        if (triggerImg) {
          img.src = triggerImg.src;
          img.alt = triggerImg.alt;
        }
        if (triggerLabel) {
          label.textContent = triggerLabel.textContent;
        }
        overlay.classList.remove('hidden');
        overlay.classList.add('flex');
        document.body.style.overflow = 'hidden';
      });
    }

    // Close lightbox
    const closeLightbox = () => {
      overlay.classList.add('hidden');
      overlay.classList.remove('flex');
      document.body.style.overflow = '';
    };

    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeLightbox();
    });
    closeBtn?.addEventListener('click', closeLightbox);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeLightbox();
    });
  });
</script>
