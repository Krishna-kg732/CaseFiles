---
import { SEVERITY_COLORS, SEVERITY_LABELS } from '@lib/severity';
import type { Severity, Status } from '@types/case';

interface Props {
  title: string;
  caseNumber: string;
  severity: Severity;
  status: Status;
  date: Date;
  readingTime: string;
  tags?: string[];
  slug: string;
}

const { title, caseNumber, severity, status, date, readingTime, tags, slug } = Astro.props;
const colors = SEVERITY_COLORS[severity];
const label = SEVERITY_LABELS[severity];
const dateStr = date.toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const statusColors: Record<Status, string> = {
  resolved: 'bg-stamp-green/10 text-stamp-green border-stamp-green/30',
  investigating: 'bg-stamp-red/10 text-stamp-red border-stamp-red/30',
  monitoring: 'bg-stamp-amber/10 text-stamp-amber border-stamp-amber/30',
};
---

<header class="mb-8" transition:name={`case-header-${slug}`}>
  <!-- Top row: case number & status -->
  <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
    <div class="flex items-center gap-3">
      <span class="font-mono text-xs text-ink-muted dark:text-dark-muted uppercase tracking-widest">
        Case File
      </span>
      <span class="font-mono text-sm font-bold text-ink dark:text-dark-text bg-manila-200 dark:bg-dark-card px-2.5 py-1 rounded-sm border border-manila-300 dark:border-dark-border">
        #{caseNumber}
      </span>
    </div>

    <div class="flex items-center gap-3">
      <!-- Status badge -->
      <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-sm font-mono text-xs font-medium border ${statusColors[status]}`}>
        {status === 'investigating' && <span class="w-1.5 h-1.5 rounded-full bg-stamp-red animate-pulse"></span>}
        {status.charAt(0).toUpperCase() + status.slice(1)}
      </span>

      <!-- Reading time -->
      <span class="font-mono text-xs text-ink-muted dark:text-dark-muted">
        📖 {readingTime}
      </span>
    </div>
  </div>

  <!-- Title & severity stamp -->
  <div class="flex flex-wrap items-start gap-6 mb-4">
    <h1 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-bold text-ink dark:text-dark-text leading-tight flex-1">
      {title}
    </h1>

    <!-- Severity stamp -->
    <div
      class={`severity-stamp animate ${colors.bg} ${colors.text} ${colors.border} ${colors.darkBg} text-base`}
      data-severity-stamp={slug}
    >
      <span class={`w-3 h-3 rounded-full ${colors.dot}`}></span>
      {severity} — {label}
    </div>
  </div>

  <!-- Date -->
  <div class="flex items-center gap-2 text-ink-muted dark:text-dark-muted font-mono text-sm mb-4">
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <rect x="3" y="4" width="18" height="18" rx="2" />
      <path d="M16 2v4M8 2v4M3 10h18" />
    </svg>
    {dateStr}
  </div>

  <!-- Tags -->
  {tags && tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="inline-flex items-center px-2 py-0.5 rounded-sm bg-manila-200 dark:bg-dark-card text-ink-muted dark:text-dark-muted font-mono text-[10px] uppercase tracking-wider border border-manila-300 dark:border-dark-border">
          {tag}
        </span>
      ))}
    </div>
  )}
</header>

<script>
  // Gate the stamp animation so it only plays on FIRST visit
  document.addEventListener('astro:page-load', () => {
    const readCases: string[] = JSON.parse(localStorage.getItem('read-cases') || '[]');
    for (const stamp of document.querySelectorAll<HTMLElement>('[data-severity-stamp]')) {
      const slug = stamp.dataset.severityStamp;
      if (slug && readCases.includes(slug)) {
        stamp.classList.remove('animate');
        stamp.style.opacity = '1';
      }
    }
  });
</script>
