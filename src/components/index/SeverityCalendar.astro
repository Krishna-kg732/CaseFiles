---
import { getSeverityCalendarData } from '@lib/cases';
import { SEVERITY_HEX } from '@lib/severity';

const calendarData = await getSeverityCalendarData(365);

// Group by week for GitHub-style grid
const weeks: typeof calendarData[] = [];
let currentWeek: typeof calendarData = [];
for (const day of calendarData) {
  const dayOfWeek = new Date(day.date).getDay();
  if (dayOfWeek === 0 && currentWeek.length > 0) {
    weeks.push(currentWeek);
    currentWeek = [];
  }
  currentWeek.push(day);
}
if (currentWeek.length > 0) weeks.push(currentWeek);

function getCellColor(day: typeof calendarData[0]): string {
  if (day.count === 0) return 'bg-manila-200 dark:bg-dark-border';
  if (!day.severity) return 'bg-manila-400';
  switch (day.severity) {
    case 'P0': return 'bg-stamp-red';
    case 'P1': return 'bg-stamp-amber';
    case 'P2': return 'bg-yellow-500';
    case 'P3': return 'bg-blue-500';
    default: return 'bg-manila-400';
  }
}
---

<div class="folder-card p-4">
  <h3 class="font-mono text-xs font-bold uppercase tracking-wider text-ink-muted dark:text-dark-muted mb-3 flex items-center gap-2">
    <span class="w-5 h-0.5 bg-stamp-red"></span>
    Incident Calendar
  </h3>

  <div class="overflow-x-auto scrollbar-thin">
    <div class="flex gap-0.5 min-w-max">
      {weeks.map((week) => (
        <div class="flex flex-col gap-0.5">
          {week.map((day) => (
            <div
              class={`w-3 h-3 rounded-[2px] ${getCellColor(day)} transition-colors`}
              title={`${day.date}: ${day.count} incident${day.count !== 1 ? 's' : ''}${day.severity ? ` (${day.severity})` : ''}`}
            ></div>
          ))}
        </div>
      ))}
    </div>
  </div>

  <!-- Legend -->
  <div class="flex items-center gap-3 mt-3 font-mono text-[10px] text-ink-muted dark:text-dark-muted">
    <span>Less</span>
    <div class="flex gap-0.5">
      <div class="w-3 h-3 rounded-[2px] bg-manila-200 dark:bg-dark-border"></div>
      <div class="w-3 h-3 rounded-[2px] bg-blue-500"></div>
      <div class="w-3 h-3 rounded-[2px] bg-yellow-500"></div>
      <div class="w-3 h-3 rounded-[2px] bg-stamp-amber"></div>
      <div class="w-3 h-3 rounded-[2px] bg-stamp-red"></div>
    </div>
    <span>More severe</span>
  </div>
</div>
