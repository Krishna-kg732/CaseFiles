---
import DomainTab from './DomainTab.astro';
import CaseCard from '@components/case/CaseCard.astro';
import { groupByDomain, DOMAIN_LABELS } from '@lib/cases';
import type { Domain } from '@types/case';

const groups = await groupByDomain();
const domains = Object.keys(groups) as Domain[];
---

<section id="filing-cabinet">
  <!-- Domain tabs (desktop: horizontal tabs, mobile: accordion) -->
  <div class="hidden sm:flex flex-wrap items-end gap-0.5 border-b border-manila-300 dark:border-dark-border mb-6" id="desktop-tabs">
    <DomainTab domain="all" label="All Cases" active={true} />
    {domains.map((domain) => (
      <DomainTab
        domain={domain}
        label={DOMAIN_LABELS[domain]}
        count={groups[domain].length}
        active={false}
      />
    ))}
  </div>

  <!-- Mobile: accordion -->
  <div class="sm:hidden space-y-2 mb-6" id="mobile-accordion">
    <button
      class="domain-tab active w-full text-left"
      data-domain-mobile="all"
    >
      All Cases
    </button>
    {domains.map((domain) => (
      <button
        class="domain-tab w-full text-left"
        data-domain-mobile={domain}
      >
        {DOMAIN_LABELS[domain]}
        <span class="text-ink-muted dark:text-dark-muted text-xs ml-2">({groups[domain].length})</span>
      </button>
    ))}
  </div>

  <!-- Case card grid -->
  <div
    class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5"
    id="case-grid"
  >
    {Object.entries(groups).flatMap(([, cases]) =>
      cases.map((c) => (
        <div data-case-domain={c.data.domain} data-case-card-wrapper>
          <CaseCard slug={c.slug} data={c.data} />
        </div>
      ))
    )}
  </div>

  <!-- Empty state -->
  <div id="empty-state" class="hidden text-center py-16">
    <span class="text-5xl mb-4 block">📂</span>
    <p class="font-mono text-sm text-ink-muted dark:text-dark-muted">
      No cases found in this domain.
    </p>
  </div>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    const cards = document.querySelectorAll<HTMLElement>('[data-case-card-wrapper]');
    const emptyState = document.getElementById('empty-state');

    function filterByDomain(domain: string) {
      let visible = 0;
      for (const card of cards) {
        const cardDomain = card.dataset.caseDomain;
        const show = domain === 'all' || cardDomain === domain;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      }
      if (emptyState) {
        emptyState.classList.toggle('hidden', visible > 0);
      }
    }

    // Desktop tabs
    const desktopTabs = document.querySelectorAll<HTMLElement>('#desktop-tabs [data-domain]');
    for (const tab of desktopTabs) {
      tab.addEventListener('click', () => {
        for (const t of desktopTabs) t.classList.remove('active');
        tab.classList.add('active');
        filterByDomain(tab.dataset.domain ?? 'all');
      });
    }

    // Mobile accordion
    const mobileTabs = document.querySelectorAll<HTMLElement>('[data-domain-mobile]');
    for (const tab of mobileTabs) {
      tab.addEventListener('click', () => {
        for (const t of mobileTabs) t.classList.remove('active');
        tab.classList.add('active');
        filterByDomain(tab.dataset.domainMobile ?? 'all');
      });
    }
  });
</script>
